---
import FormattedDate from "@components/FormattedDate.astro";
import { Image } from "astro:assets";
import { POST_TAGS_ENUM, AUTHORS } from "../consts";
const { post } = Astro.props;
---

<article
  class="group flex flex-col bg-surface-container-lowest rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary/5"
>
  <a href={`/blog/posts/${post.id}`} class="block h-full">
    <div class="aspect-4/3 overflow-hidden">
      <img
        alt="Article thumbnail"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        src={post.data.heroImage?.src ??
          post.data.heroImage ??
          "/assets/blog-placeholder-1.jpg"}
      />
    </div>
    <div class="p-8 flex flex-col grow">
      <div class="flex justify-between items-center mb-4">
        <div class="space-x-2"></div>
        <span class="font-body text-[10px] text-on-surface-variant italic"
          >{(<FormattedDate date={post.data.pubDate} />)}</span
        >
      </div>
      <h3
        class="font-headline text-xl font-bold text-primary mb-4 leading-snug group-hover:text-primary-container transition-colors"
      >
        {post.data.title}
      </h3>
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {post.data.tags.map((t) => (
              <span class="inline-flex items-center bg-surface-container border border-surface-container text-on-secondary-fixed-variant px-3 py-1 rounded-full font-bold text-[10px] uppercase tracking-widest">
                {POST_TAGS_ENUM[t] ?? t}
              </span>
            ))}
          </div>
        )
      }
      <p
        class="font-body text-sm text-on-surface-variant mb-8 line-clamp-3 leading-relaxed"
      >
        {post.data.description}
      </p>
      <div
        class="mt-auto flex items-center gap-3 pt-6 border-t border-surface-container"
      >
        <div class="flex flex-wrap gap-2">
          {
            (post.data.authors && post.data.authors.length
              ? post.data.authors
              : post.data.author
                ? [post.data.author]
                : []
            ).map((a) => (
              <div class="flex items-center gap-3 bg-surface-container rounded-full px-2 py-1">
                {AUTHORS[a] ? (
                  <div class="w-6 h-6 rounded-full overflow-hidden">
                    <Image
                      src={AUTHORS[a].image}
                      alt={AUTHORS[a].name}
                      class="w-full h-full object-cover"
                    />
                  </div>
                ) : (
                  <div class="w-6 h-6 rounded-full bg-surface flex items-center justify-center font-bold text-sm">
                    {String(a).charAt(0) ?? "?"}
                  </div>
                )}
                <span class="font-headline font-semibold text-xs text-primary">
                  {AUTHORS[a] ? AUTHORS[a].name : a}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </a>
</article>
