---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <nav
    class="fixed top-4 left-1/2 -translate-x-1/2 w-[90%] max-w-7xl rounded-full border border-white/20 bg-surface/80 backdrop-blur-xl shadow-[0_8px_32px_0_rgba(0,51,88,0.1)] flex justify-between items-center px-8 py-3 z-50"
  >
    <div
      class="text-xl font-bold tracking-tighter text-sky-900 font-headline flex flex-row items-center gap-2"
    >
      <span
        class="material-symbols-outlined text-4xl text-primary-container"
        data-icon="waves">waves</span
      >
      {SITE_TITLE}
    </div>
    <div class="hidden md:flex items-center gap-8">
      <HeaderLink href={"/"}>Accueil</HeaderLink>
      <!-- <HeaderLink href={'/services'}>Services</HeaderLink> -->
      <HeaderLink href={"/blog"}>Blog</HeaderLink>
      <HeaderLink href={"/notre-equipe"}>Notre Equipe</HeaderLink>
    </div>
    <a
      href="mailto:contact@lesaffluentsdunumerique.fr"
      class="bg-primary hover:scale-105 active:scale-100 transition-all duration-300 px-6 py-2 rounded-full text-on-primary text-sm font-semibold tracking-wide shadow-lg inline-block text-center"
    >
      Contact
    </a>
  </nav>
</header>
