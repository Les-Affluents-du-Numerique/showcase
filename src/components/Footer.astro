---
const today = new Date();
---

<footer
  class="bg-slate-100 dark:bg-slate-950 w-screen relative left-1/2 right-1/2 -mx-[50vw] rounded-t-[3rem] mt-20"
>
  <div
    class="max-w-7xl mx-auto px-4 md:px-8 py-16 flex flex-col md:flex-row justify-between items-center gap-8"
  >
    <div class="text-center md:text-left">
      <div
        class="font-manrope font-extrabold text-lg text-sky-900 dark:text-sky-100 mb-2"
      >
        Les Affluents du Numérique
      </div>
      <p class="font-inter text-sm text-slate-600 dark:text-slate-400">
        © {today.getFullYear()} Les Affluents du Numérique. Tous droits réservés.
      </p>
    </div>
    <div class="flex gap-8">
      <a
        class="font-inter text-sm text-slate-500 dark:text-slate-500 hover:text-sky-600 dark:hover:text-sky-300 transition-colors"
        href="/mentions-legales">Mentions Légales</a
      >
    </div>
  </div>
</footer>
