---
import FormattedDate from "@components/FormattedDate.astro";
import { Image } from "astro:assets";
import { POST_TAGS_ENUM, AUTHORS } from "../consts";
const { post } = Astro.props;
---

<section class="mb-24">
  <div
    class="group relative grid grid-cols-1 md:grid-cols-12 gap-8 items-center"
  >
    <a
      href={`/blog/posts/${post.id}`}
      class="md:col-span-7 overflow-hidden rounded-[2.5rem] bg-surface-container-low aspect-video shadow-2xl shadow-primary/5 block"
    >
      <img
        alt={post.data.title}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        src={post.data.heroImage?.src ??
          post.data.heroImage ??
          "/assets/blog-placeholder-1.jpg"}
      />
    </a>

    <a
      href={`/blog/posts/${post.id}`}
      aria-label={post.data.title}
      class="md:col-span-5 md:-ml-20 bg-surface-container-lowest/90 backdrop-blur-md p-10 md:p-14 rounded-[2.5rem] shadow-xl block"
    >
      <div
        class="mb-4 flex flex-wrap gap-2 text-sm font-label uppercase tracking-widest text-tertiary-container font-bold"
      >
        {
          post.data.tags && post.data.tags.length > 0
            ? post.data.tags.map((t) => (
                <span class="inline-flex items-center bg-surface-container border border-surface-container text-on-secondary-fixed-variant px-3 py-1 rounded-full font-bold text-[10px] uppercase tracking-widest">
                  {POST_TAGS_ENUM[t] ?? t}
                </span>
              ))
            : "Article"
        }
        {post.data.readingTime ? ` • ${post.data.readingTime} min read` : ""}
      </div>

      <h2
        class="font-headline text-3xl md:text-4xl font-extrabold text-primary mb-6 leading-tight"
      >
        {post.data.title}
      </h2>

      <p class="font-body text-on-surface-variant mb-8 leading-relaxed">
        {post.data.description}
      </p>

      <div class="flex flex-wrap items-center gap-4">
        {
          (post.data.authors && post.data.authors.length
            ? post.data.authors
            : post.data.author
              ? [post.data.author]
              : []
          ).map((a, i, arr) => (
            <div class="flex items-center gap-4 bg-surface-container rounded-full px-3 py-2">
              {AUTHORS[a] ? (
                <div class="w-8 h-8 rounded-full overflow-hidden">
                  <Image
                    src={AUTHORS[a].image}
                    alt={AUTHORS[a].name}
                    class="w-full h-full object-cover"
                  />
                </div>
              ) : (
                <img
                  class="w-12 h-12 rounded-full object-cover"
                  src={
                    post.data.authorImage?.src ??
                    post.data.authorImage ??
                    "/assets/francois_verin_profile_picture.jpeg"
                  }
                  alt={String(a)}
                />
              )}
              <div>
                <p class="font-headline font-bold text-primary text-sm">
                  {AUTHORS[a] ? AUTHORS[a].name : a}
                </p>
                {arr.length === 1 && post.data.authorRole ? (
                  <p class="font-body text-xs text-on-surface-variant">
                    {post.data.authorRole}
                  </p>
                ) : null}
              </div>
            </div>
          ))
        }
      </div>
    </a>
  </div>
</section>
