---
import BaseHead from "@components/BaseHead.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import { SITE_DESCRIPTIONS, SITE_LANG, SITE_TITLES } from "../consts";
import { Image } from "astro:assets";
import QuoteCard from "@components/QuoteCard.astro";
import fverinImage from "../assets/francois_verin_profile_picture.jpeg";
import cdebrayImage from "../assets/christopher_debray_profile_picture.jpeg";
import dcadeauImage from "../assets/daniel_cadeau_profile_picture.jpeg";
---

<!doctype html>
<html lang={SITE_LANG}>
  <head>
    <BaseHead title={SITE_TITLES.team} description={SITE_DESCRIPTIONS.team} />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-background text-on-background font-body selection:bg-primary-container selection:text-on-primary-container"
  >
    <Header />
    <main class="pt-32">
      <!-- Hero Section -->
      <section
        class="max-w-7xl mx-auto px-8 mb-32 grid md:grid-cols-12 gap-12 items-center"
      >
        <div class="md:col-span-7">
          <h1
            class="text-5xl md:text-7xl font-headline font-extrabold text-primary mb-8 leading-tight tracking-tight"
          >
            Le flux d'idées qui <span class="editorial-underline">façonne</span> votre
            futur.
          </h1>
          <p
            class="text-xl text-on-secondary-container leading-relaxed mb-8 max-w-2xl"
          >
            Nous sommes un collectif d'experts indépendants unis par une vision
            commune : apporter aux PME les outils des grands groupes avec
            l'agilité des artisans du code.
          </p>
        </div>
        <div class="md:col-span-5 relative">
          <div
            class="aspect-square rounded-3xl overflow-hidden shadow-2xl rotate-3 scale-95 hover:rotate-0 transition-transform duration-700 ease-out"
          >
            <img
              alt="Team Collaboration"
              class="w-full h-full object-cover"
              data-alt="Modern collaborative workspace with natural light, plants, and high-end tech equipment reflecting a professional and organic atmosphere"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuC-jTEgeTsg8qOk6pUingfANOnMNSWYAzZS-ycDQvyLwLNv02FLedOzrDR08G9n7Iyl4BKPkyh3xkRsgpx0sceAZj8o_2k4cUKvCLE3hgcQI9tN7mm78JbvXkUi0e-So4YG8loPmyeJeXtDcn6BFOAQkdHmqC2M0vnaWRx-LlAmblvptIwDqU6fm_1UjdYO0fAStFh485QdPp_OLrmV1j4AzfTudS9QgaoQG3deT4A8mUeEdu7R0gK3_PJaslphc0R6FabpHJVURQ"
            />
          </div>
          <div
            class="absolute -bottom-6 -left-6 bg-tertiary text-on-tertiary px-8 py-6 rounded-2xl shadow-xl hidden md:block"
          >
            <span class="text-3xl font-headline font-bold">100%</span>
            <p class="text-sm font-label uppercase tracking-widest opacity-80">
              Indépendants &amp; Unis
            </p>
          </div>
        </div>
      </section>

      <!-- Values Section - Tonal Layering -->
      <section class="bg-surface-container-low py-32 rounded-[4rem] mb-32">
        <div class="max-w-7xl mx-auto px-8">
          <div
            class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8"
          >
            <div class="max-w-xl">
              <span
                class="text-primary font-label text-xs uppercase tracking-widest mb-4 block"
                >Notre ADN</span
              >
              <h2 class="text-4xl font-headline font-bold text-primary">
                Les piliers du collectif.
              </h2>
            </div>
            <p class="text-on-secondary-container max-w-sm italic">
              "L'affluence n'est pas qu'une question de nombre, c'est la
              convergence de forces distinctes vers un but unique."
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <!-- Value 1 -->
            <div
              class="bg-surface-container-lowest p-10 rounded-3xl transition-transform hover:-translate-y-2 duration-300"
            >
              <span
                class="material-symbols-outlined text-4xl text-primary-container mb-6"
                data-icon="waves">waves</span
              >
              <h3 class="text-xl font-headline font-bold mb-4 text-primary">
                Fluidité Numérique
              </h3>
              <p class="text-on-secondary-container leading-relaxed">
                Nous créons des interfaces qui coulent de source. Pas de
                frictions, seulement une expérience utilisateur naturelle et
                performante.
              </p>
            </div>

            <!-- Value 2 -->
            <div
              class="bg-surface-container-lowest p-10 rounded-3xl transition-transform hover:-translate-y-2 duration-300"
            >
              <span
                class="material-symbols-outlined text-4xl text-primary-container mb-6"
                data-icon="hub">hub</span
              >
              <h3 class="text-xl font-headline font-bold mb-4 text-primary">
                Force Collective
              </h3>
              <p class="text-on-secondary-container leading-relaxed">
                Chaque membre apporte une spécialité pointue. En nous
                réunissant, nous offrons une expertise 360° sans les frais de
                structure d'une agence.
              </p>
            </div>

            <!-- Value 3 -->
            <div
              class="bg-surface-container-lowest p-10 rounded-3xl transition-transform hover:-translate-y-2 duration-300"
            >
              <span
                class="material-symbols-outlined text-4xl text-primary-container mb-6"
                data-icon="verified">verified</span
              >
              <h3 class="text-xl font-headline font-bold mb-4 text-primary">
                Transparence Totale
              </h3>
              <p class="text-on-secondary-container leading-relaxed">
                Le modèle micro-entreprise garantit une relation directe avec
                ceux qui font. Pas de commerciaux, juste des artisans du
                numérique.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Team Section - Bento Style -->
      <section class="max-w-7xl mx-auto px-8 mb-40">
        <div class="text-center mb-24">
          <h2 class="text-4xl font-headline font-bold text-primary mb-4">
            Le cœur du flux.
          </h2>
          <p class="text-on-secondary-container max-w-2xl mx-auto">
            Découvrez les visages derrière les lignes de code et les pixels.
          </p>
        </div>
        <div class="grid md:grid-cols-12 gap-8 items-stretch">
          <div
            class="md:col-span-8 bg-surface-container rounded-4xl p-12 flex flex-col md:flex-row gap-12 items-center"
          >
            <div
              class="w-48 h-48 rounded-full overflow-hidden shrink-0 shadow-lg"
            >
              <Image
                alt="François - Lead Dev"
                class="w-full h-full object-cover"
                data-alt="Professional portrait of a male developer in his 30s with a confident smile, wearing a casual linen shirt, bright studio lighting"
                src={fverinImage}
              />
            </div>
            <div>
              <h3
                class="text-3xl font-headline font-extrabold text-primary mb-2"
              >
                François Verin
              </h3>
              <p
                class="text-primary-container font-label font-semibold text-sm tracking-wider uppercase mb-6"
              >
                Développeur Fullstack
              </p>
              <p class="text-on-surface-variant mb-8 leading-relaxed">
                Ancien développeur en start-up, j'ai décidé de mettre mes
                compétences au services des TPE/PME pour redonner du sens au
                développement de proximité. Passionné par l'accessibilité.
              </p>
              <div class="flex flex-wrap gap-2">
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >Next.js</span
                >
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >Astro</span
                >
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >TypeScript</span
                >
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >Nest</span
                >
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >Odoo</span
                >
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >PostgreSQL</span
                >
                <span
                  class="px-3 py-1 bg-white/50 text-xs font-label rounded-full border border-outline-variant/20"
                  >Docker</span
                >
              </div>
            </div>
          </div>

          <div
            class="md:col-span-4 bg-primary text-on-primary rounded-4xl p-10 flex flex-col justify-between"
          >
            <div>
              <div class="w-32 h-32 rounded-3xl overflow-hidden mb-8 shadow-xl">
                <Image
                  alt="Daniel - Lead Dev"
                  class="w-full h-full object-cover"
                  data-alt="Professional portrait of a male developer in his 30s with a confident smile, wearing a casual linen shirt, bright studio lighting"
                  src={dcadeauImage}
                />
              </div>
              <h3 class="text-2xl font-headline font-bold mb-1">
                Daniel Cadeau
              </h3>
              <p
                class="text-on-primary-container font-label text-xs uppercase tracking-widest mb-4"
              >
                Développeur Fullstack
              </p>
              <p class="text-on-primary/80 text-sm leading-relaxed mb-6">
                L'œil artistique du collectif. Sophie transforme des concepts
                abstraits en interfaces fluides et captivantes.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <span
                class="px-3 py-1 bg-primary-container/30 text-[10px] font-label rounded-full"
                >Figma</span
              >
              <span
                class="px-3 py-1 bg-primary-container/30 text-[10px] font-label rounded-full"
                >Webflow</span
              >
              <span
                class="px-3 py-1 bg-primary-container/30 text-[10px] font-label rounded-full"
                >Motion</span
              >
            </div>
          </div>

          <div class="col-span-1 block md:hidden">
            <QuoteCard />
          </div>

          <div class="hidden md:block lg:hidden md:col-span-12">
            <QuoteCard />
          </div>

          <div
            class="md:col-span-4 bg-primary text-on-primary rounded-4xl p-10 flex flex-col justify-between"
          >
            <div>
              <div
                class="w-32 h-32 rounded-3xl overflow-hidden mb-8 shadow-xl mr-auto flex items-center justify-center bg-primary-container/5"
              >
                <span
                  class="material-symbols-outlined text-6xl text-on-primary"
                  data-icon="code">code</span
                >
              </div>
              <h3 class="text-2xl font-headline font-bold mb-1 text-on-primary">
                Jordan
              </h3>
              <p
                class="text-on-primary-container font-label text-xs uppercase tracking-widest mb-4"
              >
                Développeur
              </p>
              <p class="text-on-primary/80 text-sm leading-relaxed mb-6">
                Passionné par les performances et les interfaces maintenables.
                Disponible pour audits et croissance produit.
              </p>
            </div>
            <div class="flex flex-wrap gap-2 justify-start mt-4">
              <span
                class="px-3 py-1 bg-primary-container/30 text-[10px] font-label rounded-full"
                >Java</span
              >
              <span
                class="px-3 py-1 bg-primary-container/30 text-[10px] font-label rounded-full"
                >Angular JS</span
              >
              <span
                class="px-3 py-1 bg-primary-container/30 text-[10px] font-label rounded-full"
                >Spring Boot</span
              >
            </div>
          </div>

          <div class="md:col-span-5 bg-surface-container-high rounded-4xl p-10">
            <div class="flex items-center gap-6 mb-8">
              <div class="w-20 h-20 rounded-full overflow-hidden shrink-0">
                <Image
                  alt="Christopher - Lead Dev"
                  class="w-full h-full object-cover"
                  data-alt="Professional portrait of a male developer in his 30s with a confident smile, wearing a casual linen shirt, bright studio lighting"
                  src={cdebrayImage}
                />
              </div>
              <div>
                <h3 class="text-xl font-headline font-bold text-primary">
                  Christopher Debray
                </h3>
                <p
                  class="text-xs font-label text-primary-container/70 uppercase"
                >
                  Spécialiste Backend &amp; API
                </p>
              </div>
            </div>
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              Le garant de la stabilité. Thomas construit des fondations solides
              et sécurisées pour vos applications les plus complexes.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="px-3 py-1 bg-surface-container-lowest text-[10px] font-label rounded-full"
                >Node.js</span
              >
              <span
                class="px-3 py-1 bg-surface-container-lowest text-[10px] font-label rounded-full"
                >Rust</span
              >
              <span
                class="px-3 py-1 bg-surface-container-lowest text-[10px] font-label rounded-full"
                >AWS</span
              >
            </div>
          </div>
          <div class="hidden lg:flex lg:col-span-3 h-full">
            <QuoteCard />
          </div>
        </div>
      </section>

      <!-- The Collective Model Section - Trust Builder -->
      <section class="max-w-7xl mx-auto px-8 mb-40">
        <div
          class="bg-surface-container-lowest rounded-[3rem] p-12 md:p-20 shadow-xl relative overflow-hidden"
        >
          <div
            class="absolute top-0 right-0 w-1/2 h-full bg-primary-container opacity-5 -skew-x-12 translate-x-1/4"
          >
          </div>
          <div class="grid md:grid-cols-2 gap-16 items-center relative z-10">
            <div>
              <h2
                class="text-4xl font-headline font-extrabold text-primary mb-8 leading-tight"
              >
                Pourquoi le modèle <br />"Indépendants Unis" ?
              </h2>
              <div class="space-y-8">
                <div class="flex gap-4">
                  <div class="bg-primary/10 p-3 rounded-xl h-fit">
                    <span
                      class="material-symbols-outlined text-primary"
                      data-icon="account_balance">account_balance</span
                    >
                  </div>
                  <div>
                    <h4 class="font-bold text-primary mb-1">
                      Simplicité Juridique
                    </h4>
                    <p class="text-on-surface-variant text-sm">
                      Chaque membre facture sa prestation. Pour vous, c'est la
                      même flexibilité qu'un freelance unique, avec la sécurité
                      d'une équipe complète.
                    </p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="bg-primary/10 p-3 rounded-xl h-fit">
                    <span
                      class="material-symbols-outlined text-primary"
                      data-icon="savings">savings</span
                    >
                  </div>
                  <div>
                    <h4 class="font-bold text-primary mb-1">Coûts Maîtrisés</h4>
                    <p class="text-on-surface-variant text-sm">
                      Pas de bureaux luxueux à financer, pas d'actionnaires à
                      rémunérer. Votre budget va 100% dans l'expertise et le
                      temps passé sur votre projet.
                    </p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="bg-primary/10 p-3 rounded-xl h-fit">
                    <span
                      class="material-symbols-outlined text-primary"
                      data-icon="handshake">handshake</span
                    >
                  </div>
                  <div>
                    <h4 class="font-bold text-primary mb-1">
                      Interlocuteurs Directs
                    </h4>
                    <p class="text-on-surface-variant text-sm">
                      Celui qui vous vend le projet est celui qui l'exécute. Pas
                      de déperdition d'information entre le commercial et la
                      production.
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="bg-surface-container rounded-3xl p-8 border border-white/50 backdrop-blur-sm"
            >
              <div class="mb-8">
                <span
                  class="text-xs font-label uppercase tracking-widest text-primary/60 font-bold mb-4 block"
                  >Note de confiance</span
                >
                <p class="text-on-secondary-container leading-relaxed italic">
                  "Nous rassurons les PME en offrant un cadre de travail
                  structuré et une responsabilité partagée. Chaque membre du
                  collectif est sélectionné pour son sérieux et son historique
                  de réussite."
                </p>
              </div>
              <div
                class="pt-8 border-t border-outline-variant/30 flex items-center gap-4"
              >
                <div
                  class="bg-tertiary-container text-on-tertiary-container px-3 py-1 rounded-full text-[10px] font-label font-bold uppercase"
                >
                  Cadre Légal Sécurisé
                </div>
                <div
                  class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-[10px] font-label font-bold uppercase"
                >
                  Facturation Unifiée
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Final CTA Section -->
      <section class="max-w-5xl mx-auto px-8 mb-20 text-center">
        <div
          class="bg-linear-to-br from-primary to-primary-container p-16 rounded-[4rem] text-on-primary shadow-2xl relative overflow-hidden"
        >
          <div
            class="absolute -top-24 -left-24 w-64 h-64 bg-white/5 rounded-full blur-3xl"
          >
          </div>
          <div
            class="absolute -bottom-24 -right-24 w-64 h-64 bg-white/5 rounded-full blur-3xl"
          >
          </div>
          <h2
            class="text-4xl md:text-5xl font-headline font-extrabold mb-8 relative z-10 leading-tight"
          >
            Prêt à naviguer <br />vers de nouveaux affluents ?
          </h2>
          <p
            class="text-on-primary-container text-lg mb-12 max-w-xl mx-auto relative z-10 font-medium"
          >
            Parlons de votre projet. Sans engagement, juste une rencontre pour
            explorer le potentiel de votre transformation numérique.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-6 justify-center relative z-10"
          >
            <a
              href="mailto:contact@lesaffluentsdunumerique.fr"
              class="bg-white text-primary px-10 py-4 rounded-full font-bold hover:scale-105 active:scale-100 transition-transform shadow-xl inline-block text-center"
            >
              Démarrer une collaboration
            </a>
            <button
              class="bg-transparent border border-white/30 text-white px-10 py-4 rounded-full font-bold hover:bg-white/10 transition-colors"
            >
              Voir nos réalisations
            </button>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body><style>
    .material-symbols-outlined {
      font-variation-settings:
        "FILL" 0,
        "wght" 400,
        "GRAD" 0,
        "opsz" 24;
    }
    .editorial-underline {
      background-image: linear-gradient(120deg, #d0e4ff 0%, #d0e4ff 100%);
      background-repeat: no-repeat;
      background-size: 100% 0.3em;
      background-position: 0 88%;
      transition: background-size 0.25s ease-in;
    }
    .editorial-underline:hover {
      background-size: 100% 0.5em;
    }
  </style>
</html>
