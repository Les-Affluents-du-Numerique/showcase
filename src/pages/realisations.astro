---
import BaseHead from "@components/BaseHead.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE_LANG, AUTHORS } from "../consts";
import { getCollection } from "astro:content";
import ContactCTA from "@components/ContactCTA.astro";

const rawProjects = await getCollection("realisations");
const projects = rawProjects.map((p) => ({
  ...p,
  _slug: p.slug ?? (p.id ? p.id.split("/").pop() : ""),
}));
---

<!doctype html>
<html lang={SITE_LANG}>
  <head>
    <BaseHead
      title={"Les Affluents du Numérique - Nos réalisations"}
      description={"Galerie de projets et études de cas"}
    />
  </head>
  <body
    class="bg-surface text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed"
  >
    <Header />
    <main>
      <!-- Hero Section -->
      <section class="relative pt-32 pb-32 px-6 md:px-8 overflow-hidden">
        <div
          class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
        >
          <div class="lg:col-span-7">
            <span
              class="font-label text-[0.75rem] uppercase tracking-[0.1em] text-primary mb-6 block font-bold"
              >Nos réalisations</span
            >
            <h1
              class="font-display text-5xl md:text-7xl font-extrabold text-primary leading-[1.1] mb-8 tracking-tighter"
            >
              Nos courants de <span class="editorial-underline">succès</span>.
            </h1>
            <p
              class="font-body text-xl text-on-surface-variant max-w-2xl leading-relaxed"
            >
              Chaque projet est un affluent qui rejoint le fleuve numérique de
              nos clients. Nous concevons des solutions sur mesure qui allient
              haute technicité et vision stratégique pour les TPE et PME
              ambitieuses.
            </p>
          </div>
          <div class="lg:col-span-5 relative hidden lg:block">
            <div
              class="aspect-square rounded-[2rem] bg-surface-container-high overflow-hidden shadow-xl transform rotate-3 scale-105"
            >
              <img
                alt="Digital flow abstraction"
                class="w-full h-full object-cover"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuAz-30w_LtOA9ADxu3QbB2_4uaIyirXTj7Ow-9aq6BbgmlLOEVl2RmoRhA7gjXDEYQgs-H2uATFGK12Xv6FYC53lMrPcWUHrcTxAzZpaYuJPSe9lCJhbundDUZ6N6fyMl6c12pk5M_TBwunrVzgo0ZVHW6SlgqZFfnlcgjgqG549RpkPJLxfOrQKVp_DEcK9LRsjp47imKCPX5Z1KBQHIJEid5eUD5J-OwndhT2qdZ_-oOXNd69hdmiQXW4c0R20atkln92IM_Rxn4L"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Featured Case Study -->
      <section class="py-32 px-8 overflow-hidden bg-primary text-on-primary">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="relative">
              <div
                class="absolute -top-10 -left-10 w-40 h-40 bg-surface-tint opacity-20 rounded-full blur-3xl"
              >
              </div>
              <img
                alt="Coding setup"
                class="rounded-2xl shadow-2xl relative z-10 w-full object-cover aspect-[4/3]"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBEawKRD1TIsmqS8yk446ND46iSEgdXR6iYIuQIXYssWggEha65UONHg1VxvuLGHUhchldUxi_d9Cj3MUOZxL5bvxHcrYIHKhMbKjuBVBl1ORM6p5sMgWXUB0LJ_xH7KAV0y1J89yD3fdDuhKaFE81KhZu1TFNb8RxD8V7ahy_YsSJRv_XGnBeSLxZSrwCAcPzoGoDiCEdrpj3wKHNc4q7VWUBO74DL8JCwKMFqN2ngNLEONs0czTh2sZN03B8Id47J7u0gghfvEABG"
              />
            </div>
            <div>
              <span
                class="font-label text-[0.75rem] uppercase tracking-[0.2em] text-on-tertiary-container mb-6 block font-bold"
                >Étude de cas majeure</span
              >
              <h2
                class="font-display text-4xl md:text-5xl font-extrabold mb-8 leading-tight tracking-tight"
              >
                Réinventer le flux logistique pour <span
                  class="text-on-tertiary-container">TransPort Europe</span
                >.
              </h2>
              <div
                class="space-y-6 text-on-primary/80 font-body text-lg leading-relaxed"
              >
                <p>
                  Le défi était colossal : migrer un système de gestion vieux de
                  15 ans vers une architecture cloud moderne sans interruption
                  de service pour les 200 agences du groupe.
                </p>
                <p>
                  Nous avons conçu un écosystème modulaire qui a réduit les
                  temps de traitement des commandes de 60%, tout en offrant une
                  interface intuitive pour les opérateurs terrain.
                </p>
              </div>
              <div
                class="mt-10 grid grid-cols-2 gap-8 py-8 border-y border-white/10"
              >
                <div>
                  <h4 class="text-3xl font-bold mb-1">3 mois</h4>
                  <p class="text-on-primary/60 text-sm">Développement agile</p>
                </div>
                <div>
                  <h4 class="text-3xl font-bold mb-1">-25%</h4>
                  <p class="text-on-primary/60 text-sm">Coûts opérationnels</p>
                </div>
              </div>
              <button
                class="mt-12 px-8 py-4 bg-surface-container-lowest text-primary rounded-full font-bold hover:scale-105 transition-all"
                >Lire l'étude complète</button
              >
            </div>
          </div>
        </div>
      </section>

      <!-- Project Gallery & Filters -->
      <section class="bg-surface-container-low py-24 px-8">
        <div class="max-w-7xl mx-auto">
          <div
            class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8"
          >
            <div>
              <h2
                class="font-display text-4xl font-bold text-primary mb-4 tracking-tight"
              >
                Galerie de projets
              </h2>
              <p class="text-on-surface-variant max-w-md">
                Explorez nos dernières interventions techniques et créatives.
              </p>
            </div>
          </div>

          <!-- Bento Project Grid (from content collection) -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
              projects.map((p, idx) => (
                <div
                  class={
                    idx === 0 ? "md:col-span-2 lg:col-span-2 group" : "group"
                  }
                >
                  <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl flex flex-col h-full">
                    {p.data.hero ? (
                      <div class="h-56 overflow-hidden">
                        <img
                          alt={p.data.title}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                          src={p.data.hero}
                        />
                      </div>
                    ) : null}
                    <div class="p-8">
                      <h3 class="font-display text-2xl font-bold text-primary mb-4">
                        {p.data.title}
                      </h3>
                      <p class="text-on-surface-variant mb-6 text-sm leading-relaxed">
                        {p.data.description}
                      </p>

                      {p.data.tech ? (
                        <div class="flex flex-wrap gap-2 mb-6">
                          {p.data.tech.map((t) => (
                            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-full">
                              {t}
                            </span>
                          ))}
                        </div>
                      ) : null}
                      <a
                        class="inline-flex items-center gap-2 text-primary font-bold text-sm hover:gap-4 transition-all"
                        href={`/realisations/${p._slug}`}
                      >
                        Voir le projet{" "}
                        <span class="material-symbols-outlined text-sm">
                          arrow_forward
                        </span>
                      </a>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <ContactCTA />
    </main>
    <Footer />

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .editorial-underline {
        position: relative;
      }
      .editorial-underline::after {
        content: "";
        position: absolute;
        bottom: 0.1em;
        left: 0;
        width: 100%;
        height: 0.3em;
        background-color: currentColor;
        opacity: 0.2;
        z-index: -1;
      }
    </style>
  </body>
</html>
